    {
      "name": "Get boards",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let resBody;\r",
              "\r",
              "pm.test(\"Should verify status code\", () =>{\r",
              "    pm.expect(pm.response.code).to.eql(200)\r",
              "    resBody=pm.response.json();\r",
              "})\r",
              "pm.test(\"Verify response time is below 500ms\", () =>{\r",
              "    pm.expect(pm.response.responseTime).to.be.lessThan(500)\r",
              "    \r",
              "})\r",
              "pm.test(\"Verify status to be a string\", () => {\r",
              "    pm.expect(pm.response.status).to.be.a(\"string\");\r",
              "})\r",
              "pm.test(\"Verify each board name is a string\", () => {\r",
              "    resBody.map(object => {\r",
              "        pm.expect(object.name).to.be.a(\"string\");\r",
              "    })\r",
              "})\r",
              "pm.test(\"Should verify content-type header exists\", () => {\r",
              "    pm.response.to.have.header(\"content-type\")\r",
              "})\r",
              "pm.test(\"Should verify content type value\", () => {\r",
              "    pm.expect(pm.response.headers.get(\"content-type\")).to.eql(\"application/json; charset=utf-8\")\r",
              "})\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
